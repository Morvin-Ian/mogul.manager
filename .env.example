# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mogul_manager

# Auth
SECRET_KEY=your-secret-key-here
# Use a separate secret for refresh tokens (falls back to SECRET_KEY if unset)
REFRESH_SECRET_KEY=your-refresh-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Secure flag on auth cookies; leave unset to infer from FRONTEND_URL scheme
# COOKIE_SECURE=true

# DeepSeek AI
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# S3-compatible storage (Cloudflare R2, AWS S3, etc.)
S3_ACCOUNT_ID=your-account-id
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
S3_CUSTOM_DOMAIN=https://your-bucket.your-domain.com
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Email (optional — for password reset)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@example.com
MAIL_USE_TLS=true

# Frontend
FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8000/api/auth/google/callback
